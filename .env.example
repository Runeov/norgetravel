# Averdi Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# AUTHENTICATION
# ===========================================

# JWT Secret for session tokens (minimum 32 characters)
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=your-32-character-minimum-secret-key

# Bcrypt hash for the initial admin account (admin@averdi.no)
# The hash is injected at runtime — the password is never stored in source control
# Generate a hash: node -e "const bcrypt=require('bcrypt'); bcrypt.hash('YourPassword',10).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# Production write mode for admin mutation APIs.
# Default behavior in production is read-only.
# Set to true to allow write mode.
# Valid true values: 1, true, yes, on
ADMIN_WRITE_ENABLED=false

# ===========================================
# RESTAURANT RATINGS — Google Places API
# ===========================================

# Enable live Google rating refresh on restaurant cards (auto-updates every 24h via ISR)
# 1. Create a project at: https://console.cloud.google.com
# 2. Enable "Places API (New)"
# 3. Create an API key, restrict it to "Places API (New)" + your domain
# 4. Add Place IDs to each restaurant in src/data/city-guides/tromso.ts
# Without this key, stored fallback ratings are used silently.
GOOGLE_PLACES_API_KEY=

# ===========================================
# MULTI-SOURCE RATINGS — enrich_ratings.py
# ===========================================

# Yelp Fusion API — https://www.yelp.com/developers/v3/manage_app
# Free tier: 500 calls/day
YELP_API_KEY=

# TripAdvisor Content API — https://www.tripadvisor.com/developers
# Free tier: 5,000 calls/month
TRIPADVISOR_API_KEY=

# Facebook Graph API — app access token ({app_id}|{app_secret})
# Requires Pages Public Content Access permission
# https://developers.facebook.com/apps
FB_ACCESS_TOKEN=

# ===========================================
# ANALYTICS
# ===========================================

# Hotjar Site ID
# Get your Site ID from: https://insights.hotjar.com/site/list
# Example: NEXT_PUBLIC_HOTJAR_ID=1234567
NEXT_PUBLIC_HOTJAR_ID=

# Google Analytics 4 Measurement ID
# Example: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ===========================================
# SITE CONFIGURATION
# ===========================================

# Public site URL (used for sitemap generation, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://averdi-next-js-git-main-pro-design.vercel.app

# Internal site URL (for server-side operations)
SITE_URL=https://averdi-next-js-git-main-pro-design.vercel.app
